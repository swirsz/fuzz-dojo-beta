--- /opt/oss-fuzz/projects/libraw/build.sh	2026-05-27 19:03:37.384068154 +0000
+++ build.sh	2026-07-16 20:08:06.129630623 +0000
@@ -16,30 +16,33 @@
 ################################################################################
 
 # copy corpuses
-cp $SRC/libraw_cr2_fuzzer_seed_corpus.zip \
-    $SRC/libraw_nef_fuzzer_seed_corpus.zip \
-    $SRC/libraw_raf_fuzzer_seed_corpus.zip \
-    $OUT/
+cp "$SRC/libraw_cr2_fuzzer_seed_corpus.zip" \
+    "$SRC/libraw_nef_fuzzer_seed_corpus.zip" \
+    "$SRC/libraw_raf_fuzzer_seed_corpus.zip" \
+    "$OUT/"
 
 # build project
+# Disable shared libraries because this environment's libc++.a is not PIC-safe
+# and fails when linked into libraw.so. The fuzzers below link libraw.a directly.
 autoreconf --install
-./configure --disable-examples
-make -j$(nproc)
+./configure --disable-examples --disable-shared --enable-static
+make -j"$(nproc)"
 
 # build fuzzers
 export CXXFLAGS="${CXXFLAGS} -std=c++17"
 $CXX $CXXFLAGS -Ilibraw \
-    $SRC/libraw_fuzzer.cc -o $OUT/libraw_fuzzer \
-    $LIB_FUZZING_ENGINE -lz lib/.libs/libraw.a
+    "$SRC/libraw_fuzzer.cc" -o "$OUT/libraw_fuzzer" \
+    $LIB_FUZZING_ENGINE lib/.libs/libraw.a -ljpeg -lz
 
 $CXX $CXXFLAGS -Ilibraw \
-    $SRC/libraw_fuzzer.cc -o $OUT/libraw_cr2_fuzzer \
-    $LIB_FUZZING_ENGINE -lz lib/.libs/libraw.a
+    "$SRC/libraw_fuzzer.cc" -o "$OUT/libraw_cr2_fuzzer" \
+    $LIB_FUZZING_ENGINE lib/.libs/libraw.a -ljpeg -lz
 
 $CXX $CXXFLAGS -Ilibraw \
-    $SRC/libraw_fuzzer.cc -o $OUT/libraw_nef_fuzzer \
-    $LIB_FUZZING_ENGINE -lz lib/.libs/libraw.a
+    "$SRC/libraw_fuzzer.cc" -o "$OUT/libraw_nef_fuzzer" \
+    $LIB_FUZZING_ENGINE lib/.libs/libraw.a -ljpeg -lz
 
 $CXX $CXXFLAGS -Ilibraw \
-    $SRC/libraw_fuzzer.cc -o $OUT/libraw_raf_fuzzer \
-    $LIB_FUZZING_ENGINE -lz lib/.libs/libraw.a
+    "$SRC/libraw_fuzzer.cc" -o "$OUT/libraw_raf_fuzzer" \
+    $LIB_FUZZING_ENGINE lib/.libs/libraw.a -ljpeg -lz
+
