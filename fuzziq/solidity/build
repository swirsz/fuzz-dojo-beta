#!/opt/pwn.college/bash
. /usr/local/sbin/e
if [ "$?" -gt 0 ]; then
    exit 1
fi
export LABEL=$1
export PROJECT_NAME=solidity
export SANITIZER=$1
if [ -z "$SANITIZER" ]; then
    export SANITIZER='none'
    export LABEL='none'$LABEL
fi

if [ ! -d "/src-orig" ]; then
#----------------------------------------------------------------------
: <<'END_COMMENT'
# ! This project was pinned after a clang bump. Please remove the pin, Try to fix any build warnings and errors, as well as runtime errors
RUN apt-get update && apt-get install -y make autoconf automake libtool \
    build-essential libbz2-dev ninja-build zlib1g-dev wget python python-dev \
    liblzma-dev uuid-dev pkg-config openjdk-8-jdk unzip mlton bison texinfo

RUN git clone --recursive -b develop https://github.com/ethereum/solidity.git solidity
RUN git clone --depth 1 https://github.com/ethereum/solidity-fuzzing-corpus.git
RUN git clone https://github.com/google/libprotobuf-mutator.git
RUN git clone --branch="v0.11.0" --recurse-submodules \
    https://github.com/ethereum/evmone.git

# Install statically built dependencies in "/usr" directory
# Install boost
RUN cd $SRC && \
    wget -q 'https://archives.boost.io/release/1.83.0/source/boost_1_83_0.tar.bz2' -O boost.tar.bz2 && \
    test "$(sha256sum boost.tar.bz2)" = "6478edfe2f3305127cffe8caf73ea0176c53769f4bf1585be237eb30798c3b8e  boost.tar.bz2" && \
    tar -xf boost.tar.bz2 && \
    rm boost.tar.bz2 && \
    cd boost_1_83_0 && \
    LIBCXX_CONFIG_INC="-I/usr/local/include/$(clang -dumpmachine)/c++/v1" && \
    CXXFLAGS="-stdlib=libc++ -pthread ${LIBCXX_CONFIG_INC}" LDFLAGS="-stdlib=libc++" ./bootstrap.sh --with-toolset=clang --prefix=/usr && \
    ./b2 toolset=clang cxxflags="-stdlib=libc++ -pthread ${LIBCXX_CONFIG_INC}" linkflags="-stdlib=libc++ -pthread" headers && \
    ./b2 toolset=clang cxxflags="-stdlib=libc++ -pthread ${LIBCXX_CONFIG_INC}" linkflags="-stdlib=libc++ -pthread" \
        link=static variant=release runtime-link=static \
        system filesystem unit_test_framework program_options \
        install -j $(($(nproc)/2)) && \
    rm -rf $SRC/boost_1_83_0

# Install libprotobuf-mutator
# Use commit prior to libprotobuf upgrade that broke solidity build
# See https://github.com/google/oss-fuzz/issues/10237
RUN cd $SRC/libprotobuf-mutator; \
    git reset --hard 212a7be1eb08e7f9c79732d2aab9b2097085d936; \
    rm -rf $SRC/LPM; \
    mkdir -p $SRC/LPM; \
    cd $SRC/LPM; \
    export CC=clang CXX=clang++; \
    export CXXFLAGS="-stdlib=libc++ -pthread"; \
    export LDFLAGS="-stdlib=libc++ -pthread"; \
    cmake $SRC/libprotobuf-mutator -GNinja \
    -DLIB_PROTO_MUTATOR_DOWNLOAD_PROTOBUF=ON -DLIB_PROTO_MUTATOR_TESTING=OFF \
    -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX="/usr" \
    -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ \
    -DCMAKE_CXX_FLAGS="-stdlib=libc++ -pthread -D_LIBCPP_ENABLE_CXX20_REMOVED_CHAR_TRAITS" \
    -DCMAKE_EXE_LINKER_FLAGS="-stdlib=libc++ -pthread" \
    -DCMAKE_SHARED_LINKER_FLAGS="-stdlib=libc++ -pthread"; \
    ninja; \
    ninja install; \
    cd external.protobuf; \
    cp -Rf bin include /usr; \
    find lib -maxdepth 1 -type f -name 'libprotobuf*.a' -exec cp -f {} /usr/lib/ \;; \
    find lib -maxdepth 1 -type f -name 'libprotoc*.a' -exec cp -f {} /usr/lib/ \;; \
    cp -f /usr/lib/libprotobuf*.a /lib/; \
    cp -f /usr/lib/libprotoc*.a /lib/ 2>/dev/null || true; \
    cp -f /usr/lib/libprotobuf-mutator*.a /lib/ 2>/dev/null || true; \
    ! nm -C /usr/lib/libprotobuf.a | grep -qE 'std::__cxx11|std::_V2'; \
    nm -C /usr/lib/libprotobuf.a | grep -q 'std::__1'; \
    nm -C /lib/libprotobuf.a | grep -q 'google::protobuf::Reflection::FieldSize'; \
    for mutator_archive in /usr/lib/libprotobuf-mutator.a /usr/lib/libprotobuf-mutator-libfuzzer.a; do \
        test -f "$mutator_archive" || continue; \
        merged_archive="${mutator_archive}.merged"; \
        printf 'CREATE %s\nADDLIB %s\nADDLIB /usr/lib/libprotobuf.a\nSAVE\nEND\n' \
            "$merged_archive" "$mutator_archive" | ar -M; \
        mv -f "$merged_archive" "$mutator_archive"; \
        ranlib "$mutator_archive"; \
        cp -f "$mutator_archive" /lib/; \
    done; \
    nm -C /lib/libprotobuf-mutator.a | grep -q 'google::protobuf::Reflection::FieldSize';

# Install evmone
RUN cd $SRC/evmone; \
    mkdir -p build; \
    cd build; \
    # evmone 0.11/EVMC uses basic_string<unsigned char>. New libc++ releases
# hide the generic char_traits specialization unless this compatibility macro is set.
CC=clang CXX=clang++ cmake .. -G Ninja \
    -DBUILD_SHARED_LIBS=OFF \
    -DEVMONE_TESTING=OFF \
    -DCMAKE_INSTALL_PREFIX="/usr" \
    -DCMAKE_CXX_FLAGS="-stdlib=libc++ -pthread -D_LIBCPP_ENABLE_CXX20_REMOVED_CHAR_TRAITS" \
    -DCMAKE_EXE_LINKER_FLAGS="-stdlib=libc++ -pthread"; \
    ninja; \
    ninja install/strip;

# gmp
RUN cd $SRC; \
    # Replace system installed libgmp static library
    # with sanitized version
    git clone --depth 1 --branch gmp-6.2.1 https://github.com/gmp-mirror/gmp-6.2 gmp/; \
    rm -r gmp/.git/; \
    test \
        "$(tar --create gmp/ --sort=name --mtime=1970-01-01Z --owner=0 --group=0 --numeric-owner | sha256sum)" = \
        "d606ff6a4ce98692f9920031e85ea8fcf4a65ce1426f6f0048b8794aefed174b  -"; \
    # NOTE: This removes also libgmp.so, which git depends on
    rm -f /usr/lib/x86_64-linux-gnu/libgmp.*; \
    rm -f /usr/include/x86_64-linux-gnu/gmp.h; \
    cd gmp; \
    autoreconf -i; \
    ./configure --prefix=/usr --enable-static=yes --enable-maintainer-mode; \
    make -j; \
    make check; \
    make install; \
    rm -rf $SRC/gmp;

# libabicoder
RUN set -ex; \
    cd /usr/src; \
    git clone https://github.com/ekpyron/Yul-Isabelle; \
    cd Yul-Isabelle; \
    cd libabicoder; \
    CXX=clang++ CXXFLAGS="-stdlib=libc++ -pthread" make; \
    cp libabicoder.a /usr/lib; \
    cp abicoder.hpp /usr/include; \
    cd /; \
    rm -rf /usr/src/Yul-Isabelle

COPY build.sh $SRC/
END_COMMENT
#-----------------

echo Please wait, initial copy of solidity
cp -r /downloads/solidity $SRC
echo Please wait, initial copy of solidity corpus
cp -r /downloads/solidity-fuzzing-corpus $SRC
echo Please wait, initial copy of libprotobuf
cp -r /downloads/libprotobuf-mutator $SRC
#echo Please wait, initial copy of evmone
#cp -r /downloads/evmone $SRC

# Install statically built dependencies in "/usr" directory
# Install boost
cd $SRC && \
    rm -f /usr/lib/libboost_*.a && \
    cp -r /downloads/boost.tar.bz2 $SRC && \
    test "$(sha256sum boost.tar.bz2)" = "6478edfe2f3305127cffe8caf73ea0176c53769f4bf1585be237eb30798c3b8e  boost.tar.bz2" && \
    tar -xf boost.tar.bz2 && \
    rm boost.tar.bz2 && \
    cd boost_1_83_0 && \
    LIBCXX_CONFIG_INC="-I/usr/local/include/$(clang -dumpmachine)/c++/v1" && \
    CXXFLAGS="-stdlib=libc++ -pthread ${LIBCXX_CONFIG_INC}" \
    LDFLAGS="-stdlib=libc++" \
        ./bootstrap.sh --with-toolset=clang --prefix=/usr && \
    ./b2 toolset=clang \
        cxxflags="-stdlib=libc++ -pthread ${LIBCXX_CONFIG_INC}" \
        linkflags="-stdlib=libc++ -pthread" \
        headers && \
    ./b2 toolset=clang \
        cxxflags="-stdlib=libc++ -pthread ${LIBCXX_CONFIG_INC}" \
        linkflags="-stdlib=libc++ -pthread" \
        link=static variant=release runtime-link=static \
        system filesystem unit_test_framework program_options \
        install -j $(($(nproc)/2)) && \
    rm -rf $SRC/boost_1_83_0

# Install libprotobuf-mutator
# Use commit prior to libprotobuf upgrade that broke solidity build
# See https://github.com/google/oss-fuzz/issues/10237
cd $SRC/libprotobuf-mutator; \
    git reset --hard 212a7be1eb08e7f9c79732d2aab9b2097085d936; \
    rm -rf $SRC/LPM; \
    mkdir -p $SRC/LPM; \
    rm -f /usr/lib/libprotobuf*.a /usr/lib/libprotoc*.a \
          /usr/lib/libprotobuf-mutator*.a /lib/libprotobuf*.a \
          /lib/libprotoc*.a /lib/libprotobuf-mutator*.a; \
    cd $SRC/LPM; \
    export CC=clang CXX=clang++; \
    export CXXFLAGS="-stdlib=libc++ -pthread"; \
    export LDFLAGS="-stdlib=libc++ -pthread"; \
    cmake $SRC/libprotobuf-mutator -GNinja \
    -DLIB_PROTO_MUTATOR_DOWNLOAD_PROTOBUF=ON -DLIB_PROTO_MUTATOR_TESTING=OFF \
    -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX="/usr" \
    -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ \
    -DCMAKE_CXX_FLAGS="-stdlib=libc++ -pthread -D_LIBCPP_ENABLE_CXX20_REMOVED_CHAR_TRAITS" \
    -DCMAKE_EXE_LINKER_FLAGS="-stdlib=libc++ -pthread" \
    -DCMAKE_SHARED_LINKER_FLAGS="-stdlib=libc++ -pthread"; \
    ninja; \
    ninja install; \
    cd external.protobuf; \
    cp -Rf bin include /usr; \
    find lib -maxdepth 1 -type f -name 'libprotobuf*.a' -exec cp -f {} /usr/lib/ \;; \
    find lib -maxdepth 1 -type f -name 'libprotoc*.a' -exec cp -f {} /usr/lib/ \;; \
    cp -f /usr/lib/libprotobuf*.a /lib/; \
    cp -f /usr/lib/libprotoc*.a /lib/ 2>/dev/null || true; \
    cp -f /usr/lib/libprotobuf-mutator*.a /lib/ 2>/dev/null || true; \
    ! nm -C /usr/lib/libprotobuf.a | grep -qE 'std::__cxx11|std::_V2'; \
    nm -C /usr/lib/libprotobuf.a | grep -q 'std::__1'; \
    nm -C /lib/libprotobuf.a | grep -q 'google::protobuf::Reflection::FieldSize'; \
    for mutator_archive in /usr/lib/libprotobuf-mutator.a /usr/lib/libprotobuf-mutator-libfuzzer.a; do \
        test -f "$mutator_archive" || continue; \
        merged_archive="${mutator_archive}.merged"; \
        printf 'CREATE %s\nADDLIB %s\nADDLIB /usr/lib/libprotobuf.a\nSAVE\nEND\n' \
            "$merged_archive" "$mutator_archive" | ar -M; \
        mv -f "$merged_archive" "$mutator_archive"; \
        ranlib "$mutator_archive"; \
        cp -f "$mutator_archive" /lib/; \
    done; \
    nm -C /lib/libprotobuf-mutator.a | grep -q 'google::protobuf::Reflection::FieldSize';

# Install evmone with the same Clang/libc++ ABI used by Solidity.
# The challenge image normally provides a source checkout in /downloads/evmone.
if [ ! -d "$SRC/evmone" ]; then
    if [ -d /downloads/evmone ]; then
        echo Please wait, initial copy of evmone
        cp -r /downloads/evmone "$SRC/evmone"
    else
        echo "Missing evmone source: expected /downloads/evmone" >&2
        exit 1
    fi
fi
rm -rf "$SRC/evmone/build"
mkdir -p "$SRC/evmone/build"
cd "$SRC/evmone/build"
CC=clang CXX=clang++ cmake .. -G Ninja \
    -DBUILD_SHARED_LIBS=OFF \
    -DEVMONE_TESTING=OFF \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_C_COMPILER=clang \
    -DCMAKE_CXX_COMPILER=clang++ \
    -DCMAKE_CXX_FLAGS="-stdlib=libc++ -pthread -D_LIBCPP_ENABLE_CXX20_REMOVED_CHAR_TRAITS" \
    -DCMAKE_EXE_LINKER_FLAGS="-stdlib=libc++ -pthread" \
    -DCMAKE_SHARED_LINKER_FLAGS="-stdlib=libc++ -pthread"
ninja
ninja install
# Solidity v0.8.37 links the historical target name evmone-standalone.
# Some evmone releases only produce libevmone.a, so install a compatible
# static archive name explicitly instead of relying on a CMake target alias.
evmone_archive="$(find "$SRC/evmone/build" /usr/lib /usr/local/lib \
    -type f \
    \( -name 'libevmone-standalone.a' -o -name 'libevmone.a' \) \
    -print 2>/dev/null | head -n 1)"
if [ -z "$evmone_archive" ]; then
    echo "Unable to locate a static evmone archive" >&2
    exit 1
fi
cp -f "$evmone_archive" /usr/lib/libevmone-standalone.a
ranlib /usr/lib/libevmone-standalone.a
cp -f /usr/lib/libevmone-standalone.a /lib/libevmone-standalone.a
test -s /usr/lib/libevmone-standalone.a
# Older evmone releases do not always install the public headers.
if [ ! -f /usr/include/evmone/evmone.h ]; then
    mkdir -p /usr/include/evmone
    cp -f "$SRC/evmone/include/evmone/evmone.h" /usr/include/evmone/
fi

# gmp
cd $SRC; \
    # Replace system installed libgmp static library
    # with sanitized version
    cp -r /downloads/gmp $SRC; \
    rm -r gmp/.git/; \
    test \
        "$(tar --create gmp/ --sort=name --mtime=1970-01-01Z --owner=0 --group=0 --numeric-owner | sha256sum)" = \
        "d606ff6a4ce98692f9920031e85ea8fcf4a65ce1426f6f0048b8794aefed174b  -"; \
    cd gmp; \
    autoreconf -i; \
    ./configure --prefix=/usr --enable-static=yes --enable-maintainer-mode; \
    make -j; \
    make check; \
    make install; \
    # keep the system shared libgmp.so.* in place; only replace static artifacts if needed
    rm -f /usr/lib/x86_64-linux-gnu/libgmp.a; \
    rm -rf $SRC/gmp;

# libabicoder
set -ex; \
    cd /usr/src; \
    cp -r /downloads/Yul-Isabelle /usr/src; \
    cd Yul-Isabelle; \
    cd libabicoder; \
    CXX=clang++ CXXFLAGS="-stdlib=libc++ -pthread" make; \
    cp libabicoder.a /usr/lib; \
    cp abicoder.hpp /usr/include; \
    cd /; \
    rm -rf /usr/src/Yul-Isabelle

    #cp /downloads/aspell*.bz2 /tmp

    cp /opt/oss-fuzz/projects/solidity/build.sh $SRC/
    #cp /challenge/.fuzz-packet_seed_corpus.zip $OUT/fuzz-packet_seed_corpus.zip
    #patch -tuN $SRC/$PROJECT_NAME/ossfuzz.sh -i /challenge/.ossfuzz.patch -r -
    #patch -tuN $SRC/$PROJECT_NAME/Makefile.am -i /challenge/.Makefile.patch -r -
        
    #cp $SRC/$PROJECT_NAME/aspell_fuzzer.cpp $SRC/$PROJECT_NAME/new_fuzzer.cpp
    # Solidity's CMake build requires an eight-character lowercase commit hash.
    # Prefer repository metadata, then an explicit source revision, and finally
    # retain the pinned revision used by this challenge image.
    if git -C /src/solidity rev-parse --verify HEAD >/dev/null 2>&1; then
        git -C /src/solidity rev-parse --short=8 HEAD \
            | tr 'A-F' 'a-f' > /src/solidity/commit_hash.txt
    elif [[ "${SOLIDITY_COMMIT:-}" =~ ^[0-9a-fA-F]{8,40}$ ]]; then
        printf '%s\n' "${SOLIDITY_COMMIT:0:8}" \
            | tr 'A-F' 'a-f' > /src/solidity/commit_hash.txt
    else
        printf '%s\n' 11179a2f > /src/solidity/commit_hash.txt
    fi

    cd /
#----------------------------------------------------------------------
    build-cleanup
fi
build-srcfolders
mv /src-$LABEL /src

cd $SRC/$PROJECT_NAME
#----------------------------------------------------------------------
if [ ! -d "/home/hacker/fuzz-dojo/$PROJECT_NAME" ]; then
   mkdir -p /home/hacker/fuzz-dojo/$PROJECT_NAME
   cp $SRC/$PROJECT_NAME/test/tools/ossfuzz/*.cpp /home/hacker/fuzz-dojo/$PROJECT_NAME
   cp $SRC/build.sh /home/hacker/fuzz-dojo/$PROJECT_NAME
else
   cp /home/hacker/fuzz-dojo/$PROJECT_NAME/*.cpp $SRC/$PROJECT_NAME/test/tools/ossfuzz
   cp /home/hacker/fuzz-dojo/$PROJECT_NAME/build.sh $SRC
fi
#----------------------------------------------------------------------
if [ "$4" = "understanding" ]; then
    understanding $2 $3
elif [ "$4" = "planning" ]; then
    planning $2 $3
else
    fuzzlog
    compile
    drivers
fi
mv /src /src-$LABEL
